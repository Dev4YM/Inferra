{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://inferra.dev/schemas/inferra_observed_signal_v1.json",
  "title": "Inferra observed signal (HTTP ingest v1)",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "schema": {
      "type": "string",
      "const": "inferra.observed_signal.v1"
    },
    "timestamp": { "type": "string", "description": "RFC3339 event time" },
    "service": { "type": "string" },
    "service_id": { "type": "string" },
    "message": { "type": "string" },
    "body": { "type": "string" },
    "level": { "type": "string" },
    "severity_text": { "type": "string" },
    "signal_kind": { "type": "string", "default": "log" },
    "trace_id": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{32}$",
      "description": "W3C trace id, 32 hex chars"
    },
    "span_id": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{16}$",
      "description": "W3C span id, 16 hex chars"
    },
    "deployment_environment": { "type": "string" },
    "environment": { "type": "string" },
    "source_id": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "attributes": { "type": "object", "additionalProperties": true }
  }
}
